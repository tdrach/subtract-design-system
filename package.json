{
  "name": "@clawmachine/ds",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles/tokens": "./src/styles/tokens.scss",
    "./styles/global": "./src/styles/global.scss",
    "./styles/*": "./src/styles/*",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "preview:install": "npm install --prefix preview",
    "dev": "npm run preview:install --silent && npm run dev --prefix preview",
    "build": "npm run preview:install --silent && npm run build --prefix preview",
    "start": "npm run start --prefix preview"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18",
    "react-dom": ">=18",
    "sass": ">=1"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
